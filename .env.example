# Copy this file to .env and fill in the values.
# .env is listed in .gitignore and must NEVER be committed.

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://bookspace_user:password@db:5432/bookspace

# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Must be kept secret; rotate immediately if ever exposed.
SECRET_KEY=replace_this_with_a_secure_random_value

# Token lifetime in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend origin for CORS allow-list
FRONTEND_URL=http://localhost:3000

# Optional: Google Books API key for higher ISBN lookup quota.
# Get a free key at https://console.cloud.google.com/ → APIs & Services → Credentials
# Without it, the shared anonymous quota is used.
GOOGLE_BOOKS_API_KEY=
