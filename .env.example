# Copy this file to .env and fill in the values before running docker compose.

# Database — POSTGRES_PASSWORD and the password in DATABASE_URL must match.
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://bookspace_user:change_me_strong_password@db:5432/bookspace

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=replace_with_a_long_random_secret

# Token lifetime in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS allowed origin for the frontend (used when running backend standalone)
FRONTEND_URL=http://localhost:3000

# Optional Google Books API key — improves metadata lookup reliability
# https://console.cloud.google.com/ → Enable "Books API" → Create credentials
GOOGLE_BOOKS_API_KEY=
